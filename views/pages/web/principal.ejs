<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- Primary SEO Meta Tags -->
    <title>Principal Leadership & Academic Analytics | 2xcell Digital Learning</title>
    <meta name="description" content="2xcell empowers school principals with data-driven academic insights, leadership dashboards, and structured blended learning models to enhance student performance.">
    <meta name="keywords" content="school leadership dashboard, academic analytics, blended learning for schools, principal data tools, 2xcell education">
    
    <!-- Open Graph / Facebook (Social SEO) -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://2xcell.in/principal">
    <meta property="og:title" content="Empowering Principals with Data-Driven Learning | 2xcell">
    <meta property="og:description" content="Gain complete visibility into student progress and teacher enablement with 2xcell's centralized leadership dashboard.">
    <meta property="og:image" content="/public/web/assets/images/new-logo.png">

    <!-- Favicons -->
    <link rel="shortcut icon" href="/public/web/assets/favicon_io/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/public/web/assets/favicon_io/apple-touch-icon.png" />
    
    <!-- Canonical URL to prevent duplicate content issues -->
    <link rel="canonical" href="https://2xcell.in/principal" />

    <!-- External Assets -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="/public/web/assets/css/demoN.css" />
    <link rel="stylesheet" href="/public/web/assets/css/new.css" />
    <link rel="stylesheet" href="/public/web/assets/css/header.css" />
    <link rel="stylesheet" href="/public/web/assets/css/principal.css" />
    <link rel="stylesheet" href="/public/web/assets/css/test.css" />
    
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>

    <%- include('../../partials/web/header.ejs') %>

    <main> <!-- Use <main> for better SEO structure -->
      <section class="principal-hero">
        <div class="hero-content">
          <h1>Empowering School Leaders with <span class="highlight">Data-Driven Learning</span></h1>
          <p class="tagline">Strategic Academic Insights for Modern Principals</p>
          <p class="hero-description">
            2xcell helps school leaders enhance academic performance through
            structured digital learning, real-time tracking, and actionable
            academic insights.
          </p>
        </div>
      </section>

      <section class="principal-features">
        <h2 class="title">What 2xcell Offers to Principals</h2>
        <div class="feature-grid">
          <!-- Added 'article' tags for search engine crawling of key features -->
          <article class="feature-card">
            <div class="feature-number">01</div>
            <h3>Academic Performance Dashboard</h3>
            <p>Gain complete visibility into student progress and subject-level outcomes through a centralized leadership dashboard.</p>
          </article>

          <article class="feature-card">
            <div class="feature-number">02</div>
            <h3>Curriculum Alignment</h3>
            <p>Digitally structured content aligned with national standards, strengthening blended learning implementation.</p>
          </article>

          <article class="feature-card">
            <div class="feature-number">03</div>
            <h3>Teacher Enablement</h3>
            <p>Equip teachers with structured lesson plans, digital modules, and integrated assessment tools.</p>
          </article>
          
          <!-- ... remaining cards ... -->
        </div>
      </section>

      <!-- Structured Why Section -->
      <section class="principal-why">
        <h2 class="title">Why Leading Schools Choose 2xcell</h2>
        <div class="fs">
          <div class="fsb" id="fsb1"><h1>Structured blended learning model</h1></div>
          <div class="fsb" id="fsb2"><h1>Leadership-level performance analytics</h1></div>
          <div class="fsb" id="fsb3"><h1>Scalable school-wide implementation</h1></div>
          <div class="fsb" id="fsb4"><h1>Continuous academic support</h1></div>
        </div>
      </section>

      <section class="principal-cta">
        <h2>Partner With 2xcell</h2>
        <p>
          For partnership inquiries or school onboarding, connect with our team
          to transform your academic ecosystem.
        </p>
        <%- include('../../partials/web/cta-button.ejs') %>
      </section>
    </main>
    <%- include('../../partials/web/lead-form.ejs') %>
    <%- include('../../partials/web/footer.ejs') %>
<script src="/public/web/js/script.js"></script>
  </body>
</html>