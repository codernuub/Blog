<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Demo Video</title>
    <style>
      .body {
        display: flex;
        flex-direction: row;
        justify-content: center;
        align-items: center;
      }

      .video {
        width: 65%;
        height: 60%;
        margin-top: 5rem;
      }

      @media screen and (max-width: 420px) {
        .video {
          width: 90%;
        }
      }
    </style>
  </head>

  <body class="body">
    <video class="video" controls>
      <source class="videoBody" type="video/mp4" />
      <source class="videoBody" type="video/ogg" />
      <source class="videoBody" type="video/m4v" />
      Your browser does not support the video tag.
    </video>
  </body>
  <script>
    //Setting the source as video url
    const videoUrl = window.localStorage.getItem("videoUrl");
    document.querySelectorAll(".videoBody").forEach((video) => {
      video.src = videoUrl;
    });
  </script>
</html>
