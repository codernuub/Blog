<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta
      name="description"
      content="2Xcell is an A.I driven self-paced learning and assessment platform
    that helps a student become a ‘Super Learner’ using Hybrid and
    Blended Learning Model. It is designed keeping in mind the Future of
    Education and driving learning through data output and AI. Over the
    time it understands the teaching and assessment styles and starts
    taking over feedback."
    />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>2xcell</title>
    <link rel="shortcut icon" href="/public/web/assets/favicon_io/favicon-16x16.png" />
    <link
      rel="apple-touch-icon"
      href="/public/web/assets/favicon_io/apple-touch-icon.png"
    />
    <link rel="stylesheet" href="/public/web/assets/css/header.css" />
    <link rel="stylesheet" href="/public/web/assets/css/new.css" />
    <link rel="stylesheet" href="/public/web/assets/css/about.css" />
    <link rel="stylesheet" href="/public/web/assets/css/demo.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/owl-carousel/1.3.3/owl.carousel.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/owl-carousel/1.3.3/owl.theme.min.css"
    />
    <script
      type="text/javascript"
      src="https://code.jquery.com/jquery-1.12.0.min.js"
    ></script>
    <script
      type="text/javascript"
      src="https://cdnjs.cloudflare.com/ajax/libs/owl-carousel/1.3.3/owl.carousel.min.js"
    ></script>
    <title></title>
    <link
      href="https://fonts.googleapis.com/css2?family=Rubik:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,200;0,300;0,400;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap"
      rel="stylesheet"
    />
      <script src="https://cdn.tailwindcss.com"></script>
  </head>

  <body>

    <%- include('../../partials/web/header.ejs', {currentPath: currentPath}) %>
    
    <div id="container">
      <%- include("../../partials/web/home/intro.ejs") %>  

      <div class="l1b1">
        <a href="https://tech-basta.vercel.app/" target="">
          <img src="/public/web/assets/images/tech-basta.png" class="scale-animation" />
        </a>
      </div>

      <%- include("../../partials/web/home/chooseus.ejs") %>  
      <%- include("../../partials/web/home/aboutus.ejs") %>  

      <div class="otp_modal_bg" id="otp_modal_bg">
        <div class="otp_modal" id="otp_modal">
          <h3>Enter 6-digit OTP</h3>
          <input type="text" id="otp_input" />
          <span>
            <button type="button">Resend OTP</button>
            <button type="button" onClick="submitOTP()">Submit</button>
          </span>
        </div>
      </div>
      <div class="numbers">
        <div class="n1">
          <h1>Our Strength in Numbers</h1>
          <!-- <p>There are many variations of passages of Lorem Ipsum available, but the majority have suffered alteration in some form, by injected humour</p> -->
        </div>

        <div class="n2">
          <div class="n21" id="n33">
            <h1><span id="value">50</span>K+</h1>
            <p id="num">Successful Students</p>
          </div>
          <div class="n22" id="n33">
            <h1><span id="value">1350</span>+</h1>
            <p id="num">Enroll Schools</p>
          </div>
          <div class="n23" id="n33">
            <h1><span id="value">650</span>+</h1>
            <p id="num">Expert Instructor</p>
          </div>
          <div class="n24" id="n33">
            <h1><span id="value">182</span>0+</h1>
            <p id="num">Members</p>
          </div>
        </div>
      </div>

      <div class="enroll">
        <h1>Course Demo Videos</h1>
        <button id="more"><a href="/demo">Browse Course</a></button>
      </div>

      <div class="demo">
        <div class="dbox">
          <div class="dt">
            <video width="300" height="240" controls>
              <source
                src="https://xcell-cms-files.s3.ap-south-1.amazonaws.com/Demo_Grade2/II_Addition+of+3+digits+number.mp4"
                type="video/mp4"
              />
              <source
                src="https://xcell-cms-files.s3.ap-south-1.amazonaws.com/Demo_Grade2/II_Addition+of+3+digits+number.mp4"
                type="video/ogg"
              />
            </video>
          </div>

          <div class="db">
            <div class="db1">
              <h1></h1>
              <!-- <span class="timer">8h 17min</span> -->
            </div>

            <div class="db2">Addition of 3 Digit Numbers</div>

            <div class="db3">
              <p class="grade">Grade 2</p>
              <p class="views">2,526,471 Views</p>
            </div>
          </div>
        </div>

        <div class="dbox">
          <div class="dt">
            <video width="300" height="240" controls>
              <source
                src="https://xcell-cms-files.s3.ap-south-1.amazonaws.com/Demo_Grade4/Rotation+and+Revolution.mp4
                    "
                type="video/mp4"
              />
              <source
                src="https://xcell-cms-files.s3.ap-south-1.amazonaws.com/Demo_Grade4/Rotation+and+Revolution.mp4
                    "
                type="video/ogg"
              />
            </video>
          </div>

          <div class="db">
            <div class="db1">
              <h1></h1>
              <!-- <span class="timer">8h 17min</span> -->
            </div>

            <div class="db2">Rotation and Revolution</div>

            <div class="db3">
              <p class="grade">Grade 4</p>
              <p class="views">1,598,211 Views</p>
            </div>
          </div>
        </div>

        <div class="dbox">
          <div class="dt">
            <video width="300" height="240" controls>
              <source
                src="https://xcell-cms-files.s3.amazonaws.com/main.m4v"
                type="video/mp4"
              />
              <source
                src="https://xcell-cms-files.s3.amazonaws.com/main.m4v"
                type="video/ogg"
              />
              Your browser does not support the video tag.
            </video>
          </div>

          <div class="db">
            <div class="db1">
              <h1></h1>
              <!-- <span class="timer">8h 17min</span> -->
            </div>

            <div class="db2">Flower</div>

            <div class="db3">
              <p class="grade">Grade 4</p>
              <p class="views">5,576,271 Views</p>
            </div>
          </div>
        </div>
      </div>

      <div class="enroll">
        <h1><span style="font-weight: 700">Testimonials</span></h1>
        <!-- <button id="more">View More</button> -->
      </div>

      <div class="feedback">
        <button class="review_carousel_btn" onClick="slideLeft()">
          <img src="/public/web/assets/icon/arrow_left.svg" alt="<" />
        </button>
        <!-- <div class="f1">
            <p>Lorem, ipsum dolor sit amet consectetur adipisicing elit. Eos mollitia temporibus quam possimus quasi? Sint, consequuntur quasi in, voluptas praesentium laudantium consectetur porro omnis id molestiae cum perspiciatis dignissimos ad?</p>

            <br>
            <img src="">
            <img src="https://img.icons8.com/color/50/000000/user.png" />
            <h4>
                Ananya Singh
            </h4>
            <h5>
                Application Developer
            </h5>

        </div> -->
        <span class="review_carousel"> </span>
        <button class="review_carousel_btn" onClick="slideRight()">
          <img src="/public/web/assets/icon/arrow_right.svg" alt=">" />
        </button>
      </div>

      <div class="newsletter">
        <h1>To Get Latest News & Further Update</h1>
        <h2>Subscribe Our Newsletter</h2>
        <button id="subscribe" onClick="openModal()">Subscribe</button>
      </div>

      <div class="newsletter_modal_bg" id="newsletter_modal_bg">
        <div class="newsletter_modal" id="newsletter_modal">
          <h3>Enter your email address</h3>
          <input type="email" required />
          <span>
            <button type="button" onClick="closeModal()">Cancel</button>
            <button type="button">Subscribe</button>
          </span>
        </div>
      </div>

      <%- include("../../partials/web/footer") %>  
      <%- include("../../partials/web/lead-form") %>  
      <script src="/public/web/js/script.js"></script>
      <script src="/public/web/js/index.js"></script>
      <script src="/public/web/js/carousel.js" defer></script>
    </div>
  </body>
</html>
