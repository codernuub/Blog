<section
  class="relative overflow-hidden bg-gradient-to-br from-white via-indigo-50/40 to-white py-16 lg:py-24"
  aria-labelledby="hero-heading"
>
  <!-- BACKGROUND EFFECT -->
  <div
    class="absolute top-0 left-0 h-72 w-72 rounded-full bg-indigo-100/60 blur-3xl"
  ></div>

  <div
    class="absolute right-0 bottom-0 h-80 w-80 rounded-full bg-sky-100/50 blur-3xl"
  ></div>

  <div
    class="relative z-10 mx-auto flex max-w-7xl flex-col-reverse items-center gap-14 px-6 lg:flex-row lg:px-10"
  >
    <!-- LEFT CONTENT -->
    <div class="w-full lg:w-1/2">
      <!-- SMALL LABEL -->
      <div
        class="mb-5 inline-flex items-center rounded-full border border-indigo-100 bg-white px-3 lg:px-5 py-2 shadow-sm"
      >
        <span class="mr-2 h-2 w-2 rounded-full bg-indigo-500"></span>

        <p
          class="text-xs md:text-sm font-semibold uppercase tracking-[0.15em] text-[#474f85]"
        >
          AI Powered Education Platform
        </p>
      </div>

      <!-- MAIN HEADING -->
      <h1
        id="hero-heading"
        class="text-4xl font-black leading-[1.1] tracking-tight text-[#474f85] sm:text-5xl lg:text-6xl"
      >
        AI Empowered
        <span class="block"> Data Driven Blended </span>

        <span class="relative inline-block">
          Learning Platform
        </span>
      </h1>

      <!-- SUB DESCRIPTION -->
      <p class="mt-8 text-lg leading-9 text-[#36454f] sm:text-xl">
        We empower schools with an intelligent learning ecosystem that
        seamlessly integrates classroom teaching, experiential activities, and
        advanced digital tools.
      </p>

      <!-- DESCRIPTION -->
      <p class="mt-5 text-base leading-8 text-[#36454f]/90 sm:text-lg">
        Our AI-driven platform analyses student performance, identifies learning
        gaps, and delivers personalized learning pathways to ensure measurable
        academic growth. With real-time analytics, teacher support tools, and
        hybrid delivery models, we enable institutions to achieve consistent and
        sustainable learning outcomes.
      </p>

      <!-- CTA -->
      <div class="mt-10"><%- include("../cta-button") %></div>
    </div>

    <!-- RIGHT IMAGE -->
    <div class="relative flex w-full justify-center lg:w-1/2">
      <!-- GLOW -->
      <div
        class="absolute h-[420px] w-[420px] rounded-full lg:bg-indigo-200/40 blur-3xl"
      ></div>

      <!-- IMAGE CARD -->
      <div
        class="relative rounded-[2rem] border border-white/50 bg-white/70 p-4 shadow-[0_25px_80px_rgba(71,79,133,0.18)] backdrop-blur-xl"
      >
        <img
          src="/public/web/assets/images/home1.png"
          alt="AI empowered data driven blended learning platform"
          class="relative z-10 w-full max-w-md object-contain drop-shadow-2xl sm:max-w-lg"
          loading="eager"
        />
      </div>
    </div>
  </div>
</section>
