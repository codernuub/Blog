<style>
  :root {
    --primary-color: #009e7f;
    --primary-dark: #007c64;
    --bg-color: #f8fafc;
    --card-bg: #ffffff;
    --text-dark: #474585;
    --text-muted: #6b7280;
    --border-color: #e5e7eb;
    --success-color: #16a34a;
    --error-color: #dc2626;
  }

  .ev-contact-overlay {
    position: fixed;
    inset: 0;
    background: rgba(15, 23, 42, 0.65);
    backdrop-filter: blur(4px);
    z-index: 99999;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 16px;
    animation: evFadeIn 0.25s ease;
  }

  .ev-contact-overlay.ev-active {
    display: flex !important;
  }

  .ev-contact-modal {
    width: 100%;
    max-width: 430px;
    background: var(--card-bg);
    border-radius: 20px;
    overflow: hidden;
    position: relative;
    box-shadow:
      0 10px 25px rgba(0, 0, 0, 0.08),
      0 20px 48px rgba(0, 0, 0, 0.12);
    animation: evSlideUp 0.3s ease;
  }

  .ev-contact-header {
    padding: 22px 22px 14px;
    background: linear-gradient(
      135deg,
      var(--primary-color),
      var(--primary-dark)
    );
    color: white;
  }

  .ev-contact-title {
    font-size: 22px;
    font-weight: 700;
    margin: 0 0 6px;
    letter-spacing: -0.4px;
    color: white !important;
  }

  .ev-contact-subtitle {
    margin: 0;
    opacity: 0.92;
    line-height: 1.45;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.92);
  }

  .ev-contact-close {
    position: absolute;
    top: 14px;
    right: 14px;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: none;
    background: rgba(255, 255, 255, 0.18);
    color: white;
    cursor: pointer;
    font-size: 17px;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    margin: 0 !important;
  }

  .ev-contact-close:hover {
    background: rgba(255, 255, 255, 0.28);
    transform: rotate(90deg);
  }

  .ev-contact-body {
    padding: 20px 22px 24px;
    background: var(--bg-color);
  }

  .ev-contact-form {
    width: 100% !important;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .ev-contact-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .ev-contact-label {
    font-size: 13px;
    font-weight: 600;
    margin: 0 !important;
    padding: 0 !important;
    color: var(--text-dark);
    line-height: 1.2;
  }

  .ev-contact-input,
  .ev-contact-textarea {
    width: 100%;
    border: 1px solid var(--border-color);
    background: white;
    border-radius: 12px;
    padding: 12px 14px;
    font-size: 14px;
    outline: none;
    transition: all 0.2s ease;
    color: var(--text-dark);
    box-sizing: border-box;
    margin: 0 !important;
    font-family: inherit;
  }

  .ev-contact-input::placeholder,
  .ev-contact-textarea::placeholder {
    color: #94a3b8;
  }

  .ev-contact-input:focus,
  .ev-contact-textarea:focus {
    border-color: var(--primary-color);
    box-shadow: 0 0 0 4px rgba(0, 158, 127, 0.12);
  }

  .ev-contact-textarea {
    resize: vertical;
    min-height: 90px;
  }

  .ev-contact-phone-wrapper {
    display: flex;
    align-items: center;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    overflow: hidden;
    background: white;
    transition: all 0.2s ease;
  }

  .ev-contact-phone-wrapper:focus-within {
    border-color: var(--primary-color);
    box-shadow: 0 0 0 4px rgba(0, 158, 127, 0.12);
  }

  .ev-contact-country {
    padding: 12px 13px;
    background: #f1f5f9;
    font-weight: 600;
    font-size: 14px;
    color: var(--text-dark);
    border-right: 1px solid var(--border-color);
    white-space: nowrap;
    line-height: 1;
  }

  .ev-contact-phone {
    border: none !important;
    box-shadow: none !important;
    border-radius: 0 !important;
    margin: 0 !important;
    background: transparent !important;
  }

  .ev-contact-error {
    color: var(--error-color);
    font-size: 12px;
    display: none;
    margin-top: 2px;
    line-height: 1.3;
  }

  .ev-contact-message {
    padding: 12px 14px;
    border-radius: 12px;
    font-size: 13px;
    display: none;
    line-height: 1.5;
  }

  .ev-contact-message.success {
    background: rgba(22, 163, 74, 0.12);
    color: var(--success-color);
    border: 1px solid rgba(22, 163, 74, 0.2);
  }

  .ev-contact-message.error {
    background: rgba(220, 38, 38, 0.1);
    color: var(--error-color);
    border: 1px solid rgba(220, 38, 38, 0.15);
  }

  .ev-contact-submit {
    height: 48px;
    border: none;
    border-radius: 12px;
    background: linear-gradient(
      135deg,
      var(--primary-color),
      var(--primary-dark)
    );
    color: white;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.25s ease;
    position: relative;
    overflow: hidden;
    width: 100%;
    margin: 0 !important;
  }

  .ev-contact-submit:hover {
    transform: translateY(-1px);
    box-shadow: 0 12px 24px rgba(0, 158, 127, 0.22);
  }

  .ev-contact-submit:disabled {
    opacity: 0.7;
    cursor: not-allowed;
    transform: none;
  }

  .ev-contact-loader {
    width: 16px;
    height: 16px;
    border: 2px solid rgba(255, 255, 255, 0.4);
    border-top-color: white;
    border-radius: 50%;
    display: inline-block;
    animation: evSpin 0.8s linear infinite;
    vertical-align: middle;
  }

  @keyframes evSpin {
    to {
      transform: rotate(360deg);
    }
  }

  @keyframes evFadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes evSlideUp {
    from {
      transform: translateY(20px);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  @media (max-width: 640px) {
    .ev-contact-overlay {
      padding: 12px;
    }

    .ev-contact-modal {
      max-width: 100%;
      border-radius: 18px;
    }

    .ev-contact-header {
      padding: 20px 18px 14px;
    }

    .ev-contact-body {
      padding: 18px 18px 22px;
    }

    .ev-contact-title {
      font-size: 20px;
    }

    .ev-contact-subtitle {
      font-size: 12px;
    }
  }
</style>
<div class="ev-contact-overlay" id="evContactPopup">
  <div class="ev-contact-modal">
    <button
      type="button"
      class="ev-contact-close"
      id="evContactClose"
    >
      ✕
    </button>

    <div class="ev-contact-header">
      <h2 class="ev-contact-title">Get In Touch</h2>
      <p class="ev-contact-subtitle">
        Have questions or want to discuss something? Fill out the form and our team will contact you shortly.
      </p>
    </div>

    <div class="ev-contact-body">
      <form id="evContactForm" class="ev-contact-form">
        <div
          class="ev-contact-message"
          id="evContactMessage"
        ></div>

        <div class="ev-contact-group">
          <label class="ev-contact-label">Full Name</label>

          <input
            type="text"
            name="name"
            class="ev-contact-input"
            placeholder="Enter your full name"
            maxlength="60"
          />

          <span class="ev-contact-error"></span>
        </div>

        <div class="ev-contact-group">
          <label class="ev-contact-label">Email Address</label>

          <input
            type="email"
            name="email"
            class="ev-contact-input"
            placeholder="Enter your email address"
            maxlength="100"
          />

          <span class="ev-contact-error"></span>
        </div>

        <div class="ev-contact-group">
          <label class="ev-contact-label">Phone Number</label>

          <div class="ev-contact-phone-wrapper">
            <div class="ev-contact-country">🇮🇳 +91</div>

            <input
              type="tel"
              name="phone"
              class="ev-contact-input ev-contact-phone"
              placeholder="9876543210"
              maxlength="10"
              inputmode="numeric"
            />
          </div>

          <span class="ev-contact-error"></span>
        </div>

        <div class="ev-contact-group">
          <label class="ev-contact-label">Message</label>

          <textarea
            name="message"
            class="ev-contact-textarea"
            placeholder="Write your message here..."
            maxlength="1000"
          ></textarea>

          <span class="ev-contact-error"></span>
        </div>

        <button
          type="submit"
          class="ev-contact-submit"
          id="evContactSubmit"
        >
          Submit Inquiry
        </button>
      </form>
    </div>
  </div>
</div>

<script>
  (() => {
    const popup = document.getElementById("evContactPopup");
    const closeBtn = document.getElementById("evContactClose");
    const form = document.getElementById("evContactForm");
    const submitBtn = document.getElementById("evContactSubmit");
    const messageBox = document.getElementById("evContactMessage");

    window.openEvContactPopup = () => {
      popup.classList.add("ev-active");
      document.body.style.overflow = "hidden";
    };

    window.closeEvContactPopup = () => {
      popup.classList.remove("ev-active");
      document.body.style.overflow = "";
    };

    closeBtn.addEventListener("click", closeEvContactPopup);

    popup.addEventListener("click", (e) => {
      if (e.target === popup) {
        closeEvContactPopup();
      }
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        closeEvContactPopup();
      }
    });

    const showMessage = (type, text) => {
      messageBox.style.display = "block";
      messageBox.className = `ev-contact-message ${type}`;
      messageBox.textContent = text;
    };

    const clearMessage = () => {
      messageBox.style.display = "none";
      messageBox.textContent = "";
    };

    const setError = (input, message) => {
      const group = input.closest(".ev-contact-group");
      const error = group.querySelector(".ev-contact-error");

      error.style.display = "block";
      error.textContent = message;
    };

    const clearErrors = () => {
      document.querySelectorAll(".ev-contact-error").forEach((el) => {
        el.style.display = "none";
        el.textContent = "";
      });
    };

    const validateForm = (data) => {
      clearErrors();

      let isValid = true;

      if (!data.name || data.name.trim().length < 2) {
        setError(form.name, "Please enter a valid name");
        isValid = false;
      }

      const emailRegex =
        /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

      if (!emailRegex.test(data.email)) {
        setError(form.email, "Please enter a valid email address");
        isValid = false;
      }

      const phoneRegex = /^[6-9]\d{9}$/;

      if (!phoneRegex.test(data.phone)) {
        setError(
          form.phone,
          "Please enter a valid 10-digit Indian phone number"
        );
        isValid = false;
      }

      if (!data.message || data.message.trim().length < 10) {
        setError(
          form.message,
          "Message should be at least 10 characters"
        );
        isValid = false;
      }

      return isValid;
    };

    form.phone.addEventListener("input", (e) => {
      e.target.value = e.target.value.replace(/\D/g, "").slice(0, 10);
    });

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      clearMessage();

      const formData = {
        name: form.name.value.trim(),
        email: form.email.value.trim(),
        phone: form.phone.value.trim(),
        message: form.message.value.trim(),
      };

      const valid = validateForm(formData);

      if (!valid) return;

      try {
        submitBtn.disabled = true;
        submitBtn.innerHTML =
          '<span class="ev-contact-loader"></span> Sending...';

        const response = await fetch("/api/v1/contacts", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify(formData),
        });

        const result = await response.json();

        if (!response.ok) {
          throw new Error(
            result.message || "Failed to submit form"
          );
        }

        showMessage(
          "success",
          result.message ||
            "Your inquiry has been submitted successfully."
        );

        form.reset();

        setTimeout(() => {
          closeEvContactPopup();
        }, 1800);
      } catch (error) {
        showMessage(
          "error",
          error.message ||
            "Something went wrong. Please try again."
        );
      } finally {
        submitBtn.disabled = false;
        submitBtn.innerHTML = "Submit Inquiry";
      }
    });
  })();
</script>